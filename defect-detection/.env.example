# Copy this file to .env and adjust for your environment.
# All values shown are the defaults — only override what you need.

# ── Camera ────────────────────────────────────────────────────────────────────
DEV_MODE=true
DEV_CAMERA_INDEX=0
GRAYSCALE_MODE=false
FRAME_RATE=30

# ── Detection / OCR ───────────────────────────────────────────────────────────
# Minimum evidence score (0–1) to declare a batch code present.
DETECTION_THRESHOLD=0.55
# Downscale longest frame side before OCR (px). Lower = faster/less lag; the
# large batch digits stay readable. 0 = no downscale.
OCR_MAX_SIDE=960
# Minimum frame brightness before OCR is attempted (0–255).
DARK_FRAME_THRESHOLD=8.0
# Minimum gap between OCR passes (seconds). 0 = as fast as possible.
OCR_INTERVAL_S=0.0

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_DIR=data/results
# Save a JPEG snapshot alongside each CSV row (true/false).
LOG_SNAPSHOTS=true

# ── GPIO — Raspberry Pi only ─────────────────────────────────────────────────
# GPIO_BUZZER_PIN=17
# GPIO_LED_PIN=27
# Duration of each alert pulse in seconds.
# ALERT_DURATION_S=1.0

# ── Dashboard ─────────────────────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
